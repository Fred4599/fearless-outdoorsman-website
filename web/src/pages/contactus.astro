---
import Layout from "../layouts/Layout.astro";
import InteriorChrome from "../components/InteriorChrome.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import "../styles/global.css";
import { pageHeroImages } from "../data/site-images";
import { contactEmail } from "../data/site";
---

<Layout
  title="Contact | Fearless Outdoorsman"
  description="Questions about trips, applications, or donations? Contact Fearless Outdoorsman — we’re here to help."
>
  <InteriorChrome>
    <PageHero
      src={pageHeroImages.contact}
      alt="Fearless Outdoorsman in the field — reach out with questions about trips, applications, or donations"
    />
    <main class="mx-auto max-w-3xl px-6 pb-32 pt-10 md:pt-14">
      <PageIntro label="Connect" />
      <h1 class="font-heading text-4xl font-semibold tracking-tighter text-primary md:text-5xl lg:text-6xl">Get in touch</h1>
      <p class="mt-6 text-base leading-relaxed text-zinc-600">
        Whether you have questions, need more information, or want to support our mission, we’re here to connect. Send us
        a message and we’ll respond as quickly as we can — with details on programs, applications, and how you can
        contribute.
      </p>

      <form
        id="contact-form"
        class="mx-auto mt-12 max-w-2xl space-y-6 rounded-2xl border border-zinc-200/80 bg-white p-8 shadow-sm transition-colors duration-500 hover:border-primary/15 md:p-10"
        novalidate
      >
        <div>
          <label for="contact-name" class="mb-2 block text-sm font-medium text-zinc-800">Name</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="w-full rounded-xl border border-zinc-200 bg-zinc-50/80 px-4 py-3 text-sm text-zinc-900 transition-colors focus:border-secondary focus:bg-white focus:outline-none"
          />
        </div>
        <div>
          <label for="contact-email" class="mb-2 block text-sm font-medium text-zinc-800">Email</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-xl border border-zinc-200 bg-zinc-50/80 px-4 py-3 text-sm text-zinc-900 transition-colors focus:border-secondary focus:bg-white focus:outline-none"
          />
        </div>
        <div>
          <label for="contact-phone" class="mb-2 block text-sm font-medium text-zinc-800">Phone <span class="font-normal text-zinc-500">(optional)</span></label>
          <input
            id="contact-phone"
            name="phone"
            type="tel"
            autocomplete="tel"
            class="w-full rounded-xl border border-zinc-200 bg-zinc-50/80 px-4 py-3 text-sm text-zinc-900 transition-colors focus:border-secondary focus:bg-white focus:outline-none"
          />
        </div>
        <div>
          <label for="contact-message" class="mb-2 block text-sm font-medium text-zinc-800">Message</label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            class="w-full rounded-xl border border-zinc-200 bg-zinc-50/80 px-4 py-3 text-sm text-zinc-900 transition-colors focus:border-secondary focus:bg-white focus:outline-none"
          ></textarea>
        </div>
        <div class="flex gap-3">
          <input
            id="contact-agree"
            name="agree"
            type="checkbox"
            required
            class="mt-1 h-4 w-4 shrink-0 rounded border-zinc-300 text-accent focus:ring-accent"
          />
          <label for="contact-agree" class="text-sm leading-relaxed text-zinc-600">
            I agree to the
            <a href="/terms" class="font-medium text-accent underline-offset-2 hover:text-primary hover:underline"
              >terms &amp; conditions</a
            >. By providing my phone number, I agree to receive text messages from the organization where applicable.
          </label>
        </div>
        <p id="contact-form-error" class="hidden text-sm text-accent" role="alert"></p>
        <button
          type="submit"
          class="w-full rounded-full bg-accent py-4 text-sm font-semibold text-white shadow-[0_1px_5px_rgba(0,0,0,0.4)] transition-all duration-500 ease-spring hover:bg-accent/90 sm:w-auto sm:px-10"
        >
          Get in contact
        </button>
        <p class="text-xs text-zinc-500">
          Submitting opens your email app with a pre-filled message to {contactEmail}. If nothing opens, copy our address
          from the footer or call us directly.
        </p>
      </form>
    </main>
  </InteriorChrome>
</Layout>

<script define:vars={{ contactEmail }}>
  const form = document.getElementById("contact-form");
  const err = document.getElementById("contact-form-error");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form || !err) return;

    const agreeEl = form.querySelector("#contact-agree");
    if (!(agreeEl instanceof HTMLInputElement) || !agreeEl.checked) {
      err.textContent = "Please accept the terms to continue.";
      err.classList.remove("hidden");
      return;
    }
    err.classList.add("hidden");

    const name = form.querySelector("#contact-name")?.value?.trim() ?? "";
    const email = form.querySelector("#contact-email")?.value?.trim() ?? "";
    const phone = form.querySelector("#contact-phone")?.value?.trim() ?? "";
    const message = form.querySelector("#contact-message")?.value?.trim() ?? "";

    const body = [
      `Name: ${name}`,
      `Email: ${email}`,
      phone ? `Phone: ${phone}` : null,
      "",
      message,
    ]
      .filter(Boolean)
      .join("\n");

    const subject = encodeURIComponent("Website contact — Fearless Outdoorsman");
    const bodyEnc = encodeURIComponent(body);
    window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${bodyEnc}`;
  });
</script>
