---
import Layout from "../layouts/Layout.astro";
import InteriorChrome from "../components/InteriorChrome.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import "../styles/global.css";
import { pageHeroImages } from "../data/site-images";
import { donateUrl } from "../data/site";
import { buildBreadcrumbSchema, siteUrl } from "../data/seo";

const sponsorsSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteUrl}/sponsors#sponsorspage`,
  url: `${siteUrl}/sponsors`,
  name: "Sponsors — Fearless Outdoorsman",
  description:
    "Become a sponsor for Fearless Outdoorsman and help fund no-cost hunting and fishing trips for children with life-threatening illnesses and veterans with trauma.",
  about: { "@id": `${siteUrl}/#organization` },
  isPartOf: { "@id": `${siteUrl}/#website` },
};

const breadcrumbs = buildBreadcrumbSchema([
  { name: "Home", item: "/" },
  { name: "Sponsors", item: "/sponsors" },
]);
---

<Layout
  title="Sponsors | Fearless Outdoorsman Hunting & Veterans Nonprofit"
  description="Support Fearless Outdoorsman as an event or mission sponsor. Sponsorships help cover guided trip logistics, gear, licenses, travel, and participant support at no cost to families and veterans."
  keywords={["Fearless Outdoorsman sponsors", "Idaho nonprofit sponsorship", "sponsor veterans nonprofit", "sponsor hunting trips for kids"]}
  schema={[sponsorsSchema, breadcrumbs]}
>
  <InteriorChrome>
    <PageHero
      src={pageHeroImages.donors}
      alt="Fearless Outdoorsman supporters and community partners helping fund outdoor healing experiences"
    />
    <main class="mx-auto max-w-4xl px-6 pb-32 pt-10 md:pt-14">
      <PageIntro label="Partners" />
      <h1 class="font-heading text-4xl font-semibold tracking-tighter text-primary md:text-5xl lg:text-6xl">
        Sponsor the mission
      </h1>
      <div class="mt-10 space-y-6 text-base leading-relaxed text-zinc-600">
        <p>
          Sponsors make large moments possible. From annual events to full-season trip support, your business, family,
          or organization can directly fund life-changing outdoor experiences for children with life-threatening
          illnesses and veterans with trauma.
        </p>
        <p>
          We work with sponsors who want meaningful local and regional impact. Your partnership helps remove financial
          barriers so participants can focus on healing, mentorship, and time outdoors.
        </p>
      </div>

      <section class="mt-14 space-y-6">
        <h2 class="font-heading text-2xl font-semibold tracking-tight text-primary">Sponsorship can include</h2>
        <ul class="list-inside list-disc space-y-3 text-base leading-relaxed text-zinc-600 marker:text-primary">
          <li>Event sponsorship for tournaments, raffles, and community fundraisers</li>
          <li>Trip underwriting for travel, meals, lodging, and guided logistics</li>
          <li>Gear and supply support for safe, participant-ready experiences</li>
          <li>In-kind partnerships for services, equipment, and operations</li>
        </ul>
      </section>

      <section class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-2">
        <article class="rounded-2xl border border-zinc-200/80 bg-white p-7 shadow-sm transition-colors duration-500 hover:border-primary/20 hover:shadow-md">
          <h3 class="font-heading text-xl font-semibold tracking-tight text-zinc-900">Event sponsors</h3>
          <p class="mt-3 text-base leading-relaxed text-zinc-600">
            Put your brand behind high-impact fundraising events while helping us expand the number of participants we
            can serve each year.
          </p>
        </article>
        <article class="rounded-2xl border border-zinc-200/80 bg-white p-7 shadow-sm transition-colors duration-500 hover:border-primary/20 hover:shadow-md">
          <h3 class="font-heading text-xl font-semibold tracking-tight text-zinc-900">Mission sponsors</h3>
          <p class="mt-3 text-base leading-relaxed text-zinc-600">
            Support the organization year-round with strategic funding that strengthens programs, volunteers, and
            participant care.
          </p>
        </article>
      </section>

      <section
        class="mt-16 rounded-2xl border border-zinc-200/80 bg-white p-8 shadow-sm transition-colors duration-500 hover:border-primary/20 hover:shadow-md md:p-10"
      >
        <h2 class="font-heading text-2xl font-semibold tracking-tight text-primary">Start a sponsorship</h2>
        <p class="mt-4 text-base leading-relaxed text-zinc-600">
          Tell us what type of sponsorship you are considering and our team will follow up with options and next steps.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contactus"
            class="rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white shadow-[0_1px_5px_rgba(0,0,0,0.4)] transition-all duration-500 ease-spring hover:scale-[1.02] hover:bg-accent/90"
          >
            Contact for sponsorship
          </a>
          <a
            href={donateUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full border border-primary px-6 py-3 text-sm font-semibold text-primary transition hover:bg-primary/5"
          >
            Donate now
          </a>
        </div>
      </section>
    </main>
  </InteriorChrome>
</Layout>
