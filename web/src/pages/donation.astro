---
import Layout from "../layouts/Layout.astro";
import InteriorChrome from "../components/InteriorChrome.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import "../styles/global.css";
import { pageHeroImages } from "../data/site-images";
import { donateUrl } from "../data/site";
import { buildBreadcrumbSchema, siteUrl } from "../data/seo";

const donateSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteUrl}/donation#donatepage`,
  url: `${siteUrl}/donation`,
  name: "Donate to Fearless Outdoorsman — Idaho hunting and veterans nonprofit",
  description:
    "Support Fearless Outdoorsman — an Idaho hunting nonprofit, veterans nonprofit, and kids-with-illness nonprofit. Donations fund guided hunts, fishing trips, gear, licenses, and travel for children with life-threatening illnesses and veterans with trauma.",
  about: { "@id": `${siteUrl}/#organization` },
  isPartOf: { "@id": `${siteUrl}/#website` },
  potentialAction: {
    "@type": "DonateAction",
    name: "Donate via Square",
    target: donateUrl,
    recipient: { "@id": `${siteUrl}/#organization` },
  },
};

const breadcrumbs = buildBreadcrumbSchema([
  { name: "Home", item: "/" },
  { name: "Donate", item: "/donation" },
]);
---

<Layout
  title="Donate to Fearless Outdoorsman | Hunting & Veterans Nonprofit in Idaho"
  description="Donate to Fearless Outdoorsman, an Idaho hunting nonprofit and veterans nonprofit. Your gift funds no-cost guided hunting and fishing trips for children with life-threatening illnesses and veterans with PTSD or service-connected trauma."
  keywords={["donate hunting nonprofit", "donate veterans nonprofit Idaho", "donate kids with cancer outdoor nonprofit", "Square donation Fearless Outdoorsman", "tax deductible hunting charity Idaho"]}
  schema={[donateSchema, breadcrumbs]}
>
  <InteriorChrome>
    <PageHero
      src={pageHeroImages.donation}
      alt="Outdoor moments made possible by donors — Fearless Outdoorsman in the field"
    />
    <main class="mx-auto max-w-3xl px-6 pb-32 pt-10 md:pt-14">
      <PageIntro label="Support" />
      <h1 class="font-heading text-4xl font-semibold tracking-tighter text-primary md:text-5xl lg:text-6xl">
        Support our mission
      </h1>
      <p class="mt-6 text-base leading-relaxed text-zinc-600">
        Join us in empowering lives through nature by donating to Fearless Outdoorsman. Your contribution supports vital
        outdoor experiences for children with life-threatening illnesses and veterans with trauma, creating moments of
        healing, joy, and adventure.
      </p>
      <div
        class="mt-12 rounded-2xl border border-zinc-200/80 bg-white p-8 text-center shadow-sm transition-colors duration-500 hover:border-primary/20 hover:shadow-md md:p-12"
      >
        <p class="text-sm text-zinc-600">
          Secure checkout is handled through Square. Every gift helps cover trips, gear, guides, and logistics so
          participants can focus on the experience.
        </p>
        <a
          href={donateUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex rounded-full bg-accent px-10 py-4 text-sm font-semibold text-white shadow-[0_1px_5px_rgba(0,0,0,0.4)] transition-all duration-500 ease-spring hover:scale-[1.02] hover:bg-accent/90"
        >
          Donate now
        </a>
        <p class="mt-6 text-xs text-zinc-500">
          Fearless Outdoorsman is a non-profit organization. Retain your receipt for your records; consult a tax advisor
          regarding deductibility.
        </p>
      </div>
    </main>
  </InteriorChrome>
</Layout>
