---
import Layout from "../layouts/Layout.astro";
import InteriorChrome from "../components/InteriorChrome.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import "../styles/global.css";
import { pageHeroImages } from "../data/site-images";
import { eventsSortedByDate, formatEventDate, upcomingEvents } from "../data/events";
import { donateUrl } from "../data/site";
import { buildBreadcrumbSchema, siteUrl } from "../data/seo";

const events = eventsSortedByDate(upcomingEvents);

const eventsListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Upcoming Fearless Outdoorsman events",
  description:
    "Fundraisers, volunteer orientations, and community gatherings with Fearless Outdoorsman — based in Meridian, Idaho.",
  numberOfItems: events.length,
  itemListElement: events.map((event, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Event",
      name: event.title,
      startDate: event.date,
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      eventStatus: "https://schema.org/EventScheduled",
      description: event.description,
      location: {
        "@type": "Place",
        name: event.location,
        address: {
          "@type": "PostalAddress",
          addressLocality: "Meridian",
          addressRegion: "ID",
          addressCountry: "US",
        },
      },
      organizer: { "@id": `${siteUrl}/#organization` },
      url: event.detailHref ? `${siteUrl}${event.detailHref}` : `${siteUrl}/events`,
    },
  })),
};

const breadcrumbs = buildBreadcrumbSchema([
  { name: "Home", item: "/" },
  { name: "Events", item: "/events" },
]);
---

<Layout
  title="Events & Fundraisers | Fearless Outdoorsman — Meridian, Idaho"
  description="Fearless Outdoorsman events in Meridian, Idaho — annual golf tournament, benefit dinner, volunteer orientation, and youth elk season send-off. Join a hunting nonprofit and veterans nonprofit supporting kids with illness."
  keywords={["Meridian Idaho nonprofit events", "hunting nonprofit fundraiser", "veterans nonprofit benefit dinner", "golf tournament fundraiser Idaho", "Fearless Outdoorsman volunteer orientation"]}
  schema={[eventsListSchema, breadcrumbs]}
>
  <InteriorChrome>
    <PageHero
      src={pageHeroImages.events}
      alt="Community gathering outdoors — Fearless Outdoorsman events and supporters"
    />
    <main class="mx-auto max-w-7xl px-6 pb-32 pt-10 md:pt-14">
      <div class="max-w-3xl">
        <PageIntro label="Gatherings" />
        <h1 class="font-heading text-4xl font-semibold tracking-tighter text-primary md:text-5xl lg:text-6xl">
          Events
        </h1>
        <p class="mt-6 text-base leading-relaxed text-zinc-600">
          From benefit nights to volunteer orientations, these dates help us fund trips, train mentors, and welcome
          families. Details may be updated as venues confirm — check back or reach out if you would like to host or
          sponsor.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2 lg:gap-8">
        {events.map((event) => (
          <article
            class="flex h-full flex-col rounded-2xl border border-zinc-200/80 bg-white p-6 shadow-sm transition-colors duration-500 hover:border-primary/20 hover:shadow-md sm:p-8"
          >
            <p class="text-xs font-semibold uppercase tracking-widest text-accent">{formatEventDate(event.date)}</p>
            <h2 class="mt-3 font-heading text-xl font-semibold tracking-tight text-zinc-900 sm:text-2xl">{event.title}</h2>
            <p class="mt-2 text-sm font-medium text-zinc-500">{event.location}</p>
            <p class="mt-6 flex-grow text-base leading-relaxed text-zinc-600">{event.description}</p>
            <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3">
              {event.detailHref ? (
                <a
                  href={event.detailHref}
                  class="inline-flex items-center gap-2 text-sm font-semibold text-accent transition hover:text-primary"
                >
                  Event details
                  <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
                </a>
              ) : null}
              <a
                href="/contactus"
                class="inline-flex items-center gap-2 text-sm font-semibold text-zinc-600 transition hover:text-primary"
              >
                Ask a question
                <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
              </a>
            </div>
          </article>
        ))}
      </div>

      <p class="mt-12 max-w-3xl text-sm leading-relaxed text-zinc-500">
        Want to underwrite an event or trip?
        <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="font-medium text-accent hover:text-primary">
          Donate via Square
        </a>
        {" "}or
        <a href="/contactus" class="font-medium text-accent hover:text-primary">contact the team</a>.
      </p>
    </main>
  </InteriorChrome>
</Layout>
