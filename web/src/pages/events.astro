---
import Layout from "../layouts/Layout.astro";
import InteriorChrome from "../components/InteriorChrome.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import "../styles/global.css";
import { pageHeroImages } from "../data/site-images";
import { eventsSortedByDate, formatEventDate, upcomingEvents } from "../data/events";
import { donateUrl } from "../data/site";

const events = eventsSortedByDate(upcomingEvents);
---

<Layout
  title="Events | Fearless Outdoorsman"
  description="Fundraisers, volunteer gatherings, and community events with Fearless Outdoorsman — join us in Meridian and across Idaho."
>
  <InteriorChrome>
    <PageHero
      src={pageHeroImages.events}
      alt="Community gathering outdoors — Fearless Outdoorsman events and supporters"
    />
    <main class="mx-auto max-w-7xl px-6 pb-32 pt-10 md:pt-14">
      <div class="max-w-3xl">
        <PageIntro label="Gatherings" />
        <h1 class="font-heading text-4xl font-semibold tracking-tighter text-primary md:text-5xl lg:text-6xl">
          Events
        </h1>
        <p class="mt-6 text-base leading-relaxed text-zinc-600">
          From benefit nights to volunteer orientations, these dates help us fund trips, train mentors, and welcome
          families. Details may be updated as venues confirm — check back or reach out if you would like to host or
          sponsor.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2 lg:gap-8">
        {events.map((event) => (
          <article
            class="flex h-full flex-col rounded-2xl border border-zinc-200/80 bg-white p-6 shadow-sm transition-colors duration-500 hover:border-primary/20 hover:shadow-md sm:p-8"
          >
            <p class="text-xs font-semibold uppercase tracking-widest text-accent">{formatEventDate(event.date)}</p>
            <h2 class="mt-3 font-heading text-xl font-semibold tracking-tight text-zinc-900 sm:text-2xl">{event.title}</h2>
            <p class="mt-2 text-sm font-medium text-zinc-500">{event.location}</p>
            <p class="mt-6 flex-grow text-base leading-relaxed text-zinc-600">{event.description}</p>
            <a
              href="/contactus"
              class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-accent transition hover:text-primary"
            >
              Ask a question
              <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
            </a>
          </article>
        ))}
      </div>

      <p class="mt-12 max-w-3xl text-sm leading-relaxed text-zinc-500">
        Want to underwrite an event or trip?
        <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="font-medium text-accent hover:text-primary">
          Donate via Square
        </a>
        {" "}or
        <a href="/contactus" class="font-medium text-accent hover:text-primary">contact the team</a>.
      </p>
    </main>
  </InteriorChrome>
</Layout>
